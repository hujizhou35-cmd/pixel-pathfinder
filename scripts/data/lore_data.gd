# ============================================================
# 装备词条合成
# 普通 1 条 → 稀有 2 条 → 史诗 3 条 → 传说 4 条，逐级递增
# ============================================================
static func compose_item_lore(item: Dictionary) -> Array:
	var lines = []
	var prefix = str(item.get("prefix", _extract_prefix(item)))
	var key = item.get("key", "sword")
	var base = BASE_LORE.get(key, BASE_LORE["sword"])
	var seed_val = hash(item.get("name", "")) % 1000

	# 图鉴库条目文案（[0] 元素风味 / [1] 基底来历）
	var cat_lore: Array = []
	if item.has("catalog_id"):
		cat_lore = ItemCatalog.get_entry(str(item.catalog_id)).get("lore", [])

	# 第 1 条：名称来历（前缀故事）
	lines.append(PREFIX_LORE.get(prefix, "来历不明，但分量很实在。"))

	# 第 2 条（稀有+）：基底来历
	if item.rarity >= GameData.Rarity.RARE:
		lines.append(str(cat_lore[1]) if cat_lore.size() > 1 else base.origin)

	# 第 3 条（史诗+）：元素工艺 + 一段轶事
	if item.rarity >= GameData.Rarity.EPIC:
		lines.append(str(cat_lore[0]) if cat_lore.size() > 0 else base.craft)
		lines.append(EPIC_EXTRA[seed_val % EPIC_EXTRA.size()])

	# 第 4 条（传说）：传说级逸闻
	if item.rarity >= GameData.Rarity.LEGENDARY:
		lines.append(LEGENDARY_EXTRA[seed_val % LEGENDARY_EXTRA.size()])

	return lines

static func _extract_prefix(item: Dictionary) -> String:
	var nm: String = item.get("name", "")
	for p in GameData.EQUIP_PREFIXES:
		if nm.begins_with(p):
			return p
	return ""

static func get_monster_lore(key: String) -> Dictionary:
	return MONSTER_LORE.get(key, {
		"appearance": "资料缺失。", "personality": "资料缺失。", "origin": "资料缺失。",
	})

static func get_boss_lore(region: int) -> Dictionary:
	if region >= 0 and region < BOSS_LORE.size():
		return BOSS_LORE[region]
	return BOSS_LORE[0]
